# backup/services/myapp.env — Per-service backup configuration.
#
# Copy this file to backup/services/myapp.env (rename to match your service)
# and fill in the values. Files matching backup/services/*.env are gitignored.
#
# Each service gets its own Restic repository and encryption password,
# so backups are independently encrypted and restorable.
#
# This file is deployed to /etc/restic/services/myapp.env on the VPS (mode 600).

# ---------------------------------------------------------------------------
# Service identity
# ---------------------------------------------------------------------------

# Short identifier used in Restic tags and log messages.
# Must be unique across all services on this server. No spaces.
SERVICE_NAME=myapp

# ---------------------------------------------------------------------------
# Restic repository
#
# Each service should use its own repository (different path/prefix) so that
# snapshots can be managed and restored independently.
#
# S3 example:  s3:s3.amazonaws.com/mybucket/myapp-backup
# Local path:  /var/backups/restic/myapp  (for testing only)
# ---------------------------------------------------------------------------
RESTIC_REPOSITORY=s3:s3.amazonaws.com/mybucket/myapp-backup

# Encryption passphrase for this repository.
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
# Store in your password manager — losing it means losing access to all backups.
RESTIC_PASSWORD=

# ---------------------------------------------------------------------------
# PostgreSQL connection
#
# The backup service runs on the host and connects via the port exposed by
# the Docker container. DB_HOST is typically 127.0.0.1 and DB_PORT matches
# the host-side port binding in your docker-compose.yml.
# ---------------------------------------------------------------------------
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=myapp
DB_USER=myapp_user

# Leave DB_PASSWORD empty to use trust/peer authentication.
DB_PASSWORD=

# ---------------------------------------------------------------------------
# Restic snapshot filename
#
# The name of the file stored inside the Restic snapshot.
# Must be unique across services (used to retrieve the dump during restore).
# Convention: <service>-db.sql
# ---------------------------------------------------------------------------
STDIN_FILENAME=myapp-db.sql

# ---------------------------------------------------------------------------
# Post-restore verification (optional)
#
# SQL query run after a restore to confirm the database is healthy.
# Should return a row count > 0 for a good database. Comment out to skip.
# ---------------------------------------------------------------------------
# VERIFY_QUERY=SELECT COUNT(*) FROM django_migrations

# ---------------------------------------------------------------------------
# Optional service (optional, default: false)
#
# Set to "true" to skip this service gracefully if the database is unreachable
# (e.g. the container is stopped) rather than failing the entire backup run.
# Use for non-critical services that may not always be running.
# ---------------------------------------------------------------------------
# OPTIONAL=true
