# backup/services/myapp.env — Per-service backup configuration.
#
# Copy this file to backup/services/myapp.env (rename to match your service)
# and fill in the values. Files matching backup/services/*.env are gitignored.
#
# Each service gets its own Restic repository and encryption password,
# so backups are independently encrypted and restorable.
#
# This file is deployed to /etc/restic/services/myapp.env on the VPS (mode 600).

# ---------------------------------------------------------------------------
# Service identity
# ---------------------------------------------------------------------------

# Short identifier used in Restic tags and log messages.
# Must be unique across all services on this server. No spaces.
SERVICE_NAME=myapp

# ---------------------------------------------------------------------------
# Restic repository
#
# Each service should use its own repository (different path/prefix) so that
# snapshots can be managed and restored independently. This applies equally
# to files-only services — they still get a dedicated repository.
#
# S3 example:  s3:s3.amazonaws.com/mybucket/backups/myapp-backup
# Local path:  /var/backups/restic/myapp  (for testing only)
# ---------------------------------------------------------------------------
RESTIC_REPOSITORY=s3:s3.amazonaws.com/mybucket/backups/myapp-backup

# Encryption passphrase for this repository.
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
# Store in your password manager — losing it means losing access to all backups.
RESTIC_PASSWORD=

# ---------------------------------------------------------------------------
# Files-only mode
#
# Leave DB_NAME empty (or remove it) to mark this service as files-only — the
# DB block below is then ignored entirely and only BACKUP_PATHS is required.
# Use this for services whose state lives in config files / on-disk volumes
# rather than a database (e.g. Caddy, n8n config, static-site assets).
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# Database block (DB services only — ignored when DB_NAME is empty)
#
# CONTAINER_NAME      Docker container running PostgreSQL. May be either the
#                     exact container name or the Compose service/container
#                     stem (e.g. `jw_postgres` will match `deploy-jw_postgres-1`
#                     when there is a single clear match).
# DB_NAME, DB_USER    The application database inside the container.
# DB_PASSWORD         Passed via PGPASSWORD; leave empty for trust/peer auth.
# STDIN_FILENAME      Name of the SQL dump stored inside the snapshot.
#                     Must be unique across services. Convention: <service>-db.sql
# ---------------------------------------------------------------------------
CONTAINER_NAME=myapp-db
DB_NAME=myapp
DB_USER=myapp_user
DB_PASSWORD=
STDIN_FILENAME=myapp-db.sql

# ---------------------------------------------------------------------------
# File paths to back up
#
# Colon-separated list of absolute host paths. Backed up as a separate Restic
# snapshot tagged SERVICE_NAME-files, so file retention is managed independently
# from the database snapshot. On restore, files are written back to their
# original absolute paths.
#
# Required for files-only services (DB_NAME empty); optional otherwise.
#
# Use this for app data that lives outside the database — user uploads,
# generated assets, attachments, background images, config files, etc.
#
# Example (Planka):
# BACKUP_PATHS=/opt/apps/planka/data:/opt/apps/planka/backgrounds
# ---------------------------------------------------------------------------
# BACKUP_PATHS=

# ---------------------------------------------------------------------------
# Optional service (optional, default: false)
#
# Set to "true" to skip this service gracefully rather than failing the
# whole backup run.
#   - For DB services: skipped if the container is not running.
#   - For files-only services: skipped if no BACKUP_PATHS exist on disk.
# ---------------------------------------------------------------------------
# OPTIONAL=true
