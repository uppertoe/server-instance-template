# backup/config.env — Global backup configuration.
#
# Copy this file to backup/config.env and fill in real values.
# backup/config.env is gitignored — never commit it.
#
# This file is deployed to /etc/restic/config.env on the VPS (mode 600).
# It contains shared credentials used by all backup services.

# ---------------------------------------------------------------------------
# AWS S3 credentials (dedicated backup IAM user)
#
# Recommended IAM policy (scoped to your backup bucket):
#   s3:GetObject, s3:PutObject, s3:DeleteObject, s3:ListBucket
#
# Use a separate IAM user from your application user.
# The AWS helper script scopes that user to the bucket's `backups/` prefix.
# ---------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=

# ---------------------------------------------------------------------------
# Retention policy (applied to every service's repository)
#
# These values control how many snapshots Restic keeps after each run.
# They do not control how often backups run.
# The schedule comes from the Ansible variable `backup_schedule`, which
# defaults to `hourly` in the scaffold backup role.
# ---------------------------------------------------------------------------
KEEP_DAILY=7
KEEP_WEEKLY=4
KEEP_MONTHLY=6

# ---------------------------------------------------------------------------
# Email notifications (via msmtp)
#
# Set ALERT_EMAIL to receive failure alerts (and optionally success emails).
# Leave ALERT_EMAIL empty to disable notifications.
#
# SMTP_USER / SMTP_PASSWORD: set for authenticated servers (e.g. Amazon SES).
# Leave both empty for unauthenticated servers (e.g. local Postfix relay).
#
# Amazon SES SMTP credentials are separate from IAM credentials.
# Create them in the AWS console: SES → SMTP settings → Create credentials.
# ---------------------------------------------------------------------------
ALERT_EMAIL=
SMTP_HOST=
SMTP_PORT=587
SMTP_TLS=on
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=backup@example.com

# Set to "true" to receive an email on successful backup as well as failure.
NOTIFY_ON_SUCCESS=false
